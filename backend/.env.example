# Required: The connection string to your PostgreSQL database (e.g. from Neon or Supabase)
POSTGRES_URL="postgres://user:password@host:port/dbname?sslmode=require"

# Recommended: A long random string used to sign user login sessions securely
JWT_SECRET="generate-a-long-random-secret-key-here"

# Recommended: The password used to access the admin portal at /admin.html
ADMIN_PASSWORD="change-this-to-a-secure-admin-password"

# Optional: The port the server runs on (defaults to 3000)
PORT=3000
